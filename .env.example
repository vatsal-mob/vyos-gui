# ─── GUI Authentication ──────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

GUI_USERNAME=admin
# Generate hash:
#   python3 -c "
#   import hashlib
#   secret = '<SECRET_KEY>'
#   plain  = '<your-password>'
#   print(hashlib.pbkdf2_hmac('sha256', plain.encode(), secret.encode()[:16], 260000).hex())
#   "
GUI_PASSWORD_HASH=

# ─── VyOS Connection ─────────────────────────────────────────────────────────
VYOS_HOST=10.10.10.1
VYOS_PORT=22
VYOS_SSH_USER=vyos
VYOS_SSH_PASSWORD=

# Leave VYOS_API_KEY blank to use SSH-only mode.
# Enable on router: set service https api keys id gui key <key>
VYOS_API_KEY=
VYOS_API_URL=https://10.10.10.1
VYOS_TLS_VERIFY=false

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── App ─────────────────────────────────────────────────────────────────────
# Set COOKIE_SECURE=true when serving over HTTPS (recommended for production)
COOKIE_SECURE=false
